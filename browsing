<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Daily Plan</title>

  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      background: #ffffff;
      color: #0040FF;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }

    .container {
      width: 400px;
      max-width: 90%;
    }

    h1 {
      font-size: 20px;
      font-weight: 500;
      margin-bottom: 20px;
    }

    input {
      width: 100%;
      padding: 10px 0;
      font-size: 16px;
      border: none;
      border-bottom: 2px solid #ddd;
      outline: none;
      margin-bottom: 10px;
      background: transparent;
      transition: border-color 0.3s ease;
    }

    /* animated “ready to type” line */
    input:focus {
      border-bottom-color: #111;
      animation: pulse 1.2s infinite;
    }

    @keyframes pulse {
      0% { border-bottom-color: #111; }
      50% { border-bottom-color: #888; }
      100% { border-bottom-color: #111; }
    }

    ul {
      list-style: none;
      padding: 0;
      margin-top: 20px;
    }

    li {
      padding: 8px 0;
      border-bottom: 1px solid #eee;
      cursor: pointer;
    }

    li.done {
      text-decoration: line-through;
      color: #888;
    }
  </style>
</head>

<body>
  <div class="container">
    <h1>What's your plan for today?</h1>
    <input id="todo-input" />
    <ul id="todo-list"></ul>
  </div>

  <script>
    const input = document.getElementById('todo-input');
    const list = document.getElementById('todo-list');

    const todayKey = new Date().toISOString().split('T')[0];

    const stored = JSON.parse(localStorage.getItem('daily-todos') || '{}');
    if (!stored.date || stored.date !== todayKey) {
      localStorage.setItem('daily-todos', JSON.stringify({ date: todayKey, items: [] }));
    }

    function isURL(text) {
      return /^(https?:\/\/)?([\w-]+\.)+[\w-]{2,}(\/.*)?$/.test(text);
    }

    function formatLabel(url) {
      try {
        if (!url.startsWith('http')) url = 'https://' + url;
        const host = new URL(url).hostname;
        return host.replace(/^www\./, '').split('.')[0];
      } catch {
        return url;
      }
    }

    function normalizeURL(url) {
      if (!url.startsWith('http')) return 'https://' + url;
      return url;
    }

    function loadTodos() {
      const data = JSON.parse(localStorage.getItem('daily-todos'));
      list.innerHTML = '';

      data.items.forEach((item) => {
        const li = document.createElement('li');
        li.textContent = item.text;
        if (item.done) li.classList.add('done');

        li.onclick = () => {
          item.done = !item.done;
          saveTodos(data.items);
        };

        list.appendChild(li);
      });
    }

    function saveTodos(items) {
      localStorage.setItem('daily-todos', JSON.stringify({ date: todayKey, items }));
      loadTodos();
    }

    input.addEventListener('keypress', (e) => {
      if (e.key !== 'Enter') return;

      let value = input.value.trim();
      if (!value) return;

      const data = JSON.parse(localStorage.getItem('daily-todos'));

      // 🔎 Google search command: "s: something"
      if (value.toLowerCase().startsWith('s:')) {
        const query = value.slice(2).trim();
        if (query) {
          window.location.href =
            'https://www.google.com/search?q=' + encodeURIComponent(query);
        }
        input.value = '';
        return;
      }

      // 🌐 URL redirect behavior
      if (isURL(value)) {
        const url = normalizeURL(value);
        const label = formatLabel(value);

        data.items.push({ text: label, done: true });
        saveTodos(data.items);

        input.value = '';
        window.location.href = url;
        return;
      }

      // normal todo item
      data.items.push({ text: value, done: false });
      saveTodos(data.items);
      input.value = '';
    });

    loadTodos();

    // auto-focus on launch
    window.addEventListener('load', () => {
      input.focus();
    });
  </script>
</body>
</html>
